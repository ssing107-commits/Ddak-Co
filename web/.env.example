# Anthropic Console(https://console.anthropic.com/)에서 발급 — 서버(배포 환경)에서만 사용
ANTHROPIC_API_KEY=

# 선택. 비우면 앱 기본 모델 사용
ANTHROPIC_MODEL=

# GitHub Personal Access Token (레포 생성·푸시에 필요한 권한)
# 선택: 특정 사용자/조직 소유로 레포를 만들 때 로그인명 또는 조직명(비우면 토큰 소유 계정으로 조회)
GITHUB_TOKEN=
GITHUB_OWNER=

# Vercel REST API 토큰 (배포 자동화용)
VERCEL_TOKEN=
