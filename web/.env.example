# Anthropic Console(https://console.anthropic.com/)에서 발급 — 서버(배포 환경)에서만 사용
ANTHROPIC_API_KEY=

# 선택. 비우면 앱 기본 모델 사용
ANTHROPIC_MODEL=

# GitHub Personal Access Token (딱코 org 관리자 PAT)
GITHUB_TOKEN=
GITHUB_ORG=

# Vercel API 설정 (딱코 팀 배포용)
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# 선택. /api/deploy 가 배포 URL을 Supabase에 기록할 때만 필요(둘 다 비우면 기록 단계는 건너뜀)
# Supabase: public.deployments 테이블 (userId, projectName, deployUrl, createdAt 등) + RLS/정책은 프로젝트에 맞게 설정
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
