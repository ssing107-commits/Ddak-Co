# Anthropic Console(https://console.anthropic.com/)에서 발급 — 서버(배포 환경)에서만 사용
ANTHROPIC_API_KEY=

# 선택. 비우면 앱 기본 모델 사용
ANTHROPIC_MODEL=

# GitHub OAuth (Boss가 GitHub OAuth App 생성 후 설정)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Vercel REST API 토큰 (배포 자동화용)
VERCEL_TOKEN=
